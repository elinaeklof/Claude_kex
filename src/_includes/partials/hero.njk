{# HERO — slide 1 style: heading #ff9276 on #eeeeee background #}
<section class="section" aria-label="Hero">
  <div class="hero__body">
    <span class="hero__line">Next generation</span>

    {# Animated line — cycles through the PDF's listed verticals #}
    <span class="hero__line hero__line-tw" aria-live="polite" aria-label="Animated verticals">
  <span id="tw-text" class="hero__tw-text"></span>
  <span id="tw-cursor" class="hero__tw-cursor">|</span>
</span>

    <p class="hero__desc">
      A broad software portfolio for smarter customer interactions 
